# ============================================================
# RIVIERA PRIVATE AIRWAYS — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
#   cp .env.local.example .env.local
# ============================================================

# --- Resend (envoi des emails) ------------------------------
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Apps Script (Google Sheets) ---------------------
# URL de déploiement "Application Web" (accès : tout le monde)
NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# --- Adresses email (déjà remplies) -------------------------
AGENCY_EMAIL=contact@travelba.fr
SENDER_EMAIL=billets@travelba.fr

# --- Twilio (WhatsApp Business) -----------------------------
# https://twilio.com → Console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Numéro WhatsApp Twilio au format : whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# SID du template approuvé par Meta (boarding_confirmation_fr)
TWILIO_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Vercel Blob (stockage des PDFs pour WhatsApp) ----------
# Dashboard Vercel → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx
